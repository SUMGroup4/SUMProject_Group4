<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="800.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.marstravelsbookings.Main.controllers.RootLayoutController">
    <!-- ===================== TOP / HEADER ===================== -->
    <top>
        <VBox spacing="10.0" style="-fx-background-color: white;">
            <padding>
                <Insets bottom="14.0" left="18.0" right="18.0" top="18.0" />
            </padding>

            <!-- Navigation tabs (layout only) -->
            <HBox alignment="CENTER_LEFT" spacing="8.0" />

            <Label style="-fx-font-size: 28px; -fx-font-weight: 800; -fx-text-fill: #111827;" text="Mars Travels Bokningssystem" />
            <Label style="-fx-font-size: 20px; -fx-font-weight: 800; -fx-text-fill: #111827;" text="*Placeholder header*" />

            <Label style="-fx-font-size: 13px; -fx-text-fill: #6B7280;" text="Välj kategori och paket för att se innehåll och pris." wrapText="true" />

            <Separator />
        </VBox>
    </top>
    <!-- ===================== BOTTOM / BOOKING BAR ===================== -->
    <bottom>
        <VBox spacing="10.0" style="-fx-background-color: white;">
            <Separator />
            <HBox alignment="CENTER_LEFT" spacing="14.0">
                <padding>
                    <Insets bottom="16.0" left="18.0" right="18.0" top="12.0" />
                </padding>
                <Label fx:id="selectedPriceLabel" style="-fx-font-weight: 800; -fx-text-fill: #111827;" text="Sida 3/4">
                    <font>
                        <Font size="16.0" />
                    </font></Label>

                <Region HBox.hgrow="ALWAYS" />

                <Label style="-fx-text-fill: #6B7280;" />

                <Region HBox.hgrow="ALWAYS" />

                <Button fx:id="previousViewButton" onAction="#setPreviousView" cancelButton="true" style="-fx-background-color: #F3F4F6; -fx-text-fill: #111827; -fx-font-weight: 700; -fx-background-radius: 10px; -fx-padding: 10 14;" text="&lt;" />

                <Button fx:id="saveButton" defaultButton="true" style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-font-weight: 800; -fx-background-radius: 10px; -fx-padding: 10 16;" text="Spara" />
                <Button fx:id="nextViewButton" onAction="#setNextView" cancelButton="true" style="-fx-background-color: #F3F4F6; -fx-text-fill: #111827; -fx-font-weight: 700; -fx-background-radius: 10px; -fx-padding: 10 14;" text="&gt;" />
            </HBox>
        </VBox>
    </bottom>
    <center>

    </center>
</BorderPane>
