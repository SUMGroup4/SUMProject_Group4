<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.marstravelsbookings.Main.controllers.ControllerTill_Bokning_av_matpaket"
            prefWidth="1100.0" prefHeight="700.0">

    <top>
        <VBox spacing="8.0">
            <padding>
                <Insets top="12.0" right="12.0" bottom="8.0" left="12.0"/>
            </padding>

            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Label text="UC7 – Bokning av matpaket"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>

                <Button fx:id="newBookingButton" text="Ny bokning"/>
                <Button fx:id="cancelButton" text="Avbryt"/>
            </HBox>

            <ToolBar>
                <Label text="Sök:"/>
                <TextField fx:id="searchField" promptText="Sök matpaket (namn, taggar, allergener...)" prefWidth="380.0"/>
                <Separator/>
                <CheckBox fx:id="availableOnlyCheck" text="Visa endast tillgängliga"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Status:"/>
                <Label fx:id="topStatusLabel" text="Ingen pågående bokning"/>
            </ToolBar>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.28">
            <!-- Vänster: filterpanel -->
            <VBox spacing="12.0">
                <padding>
                    <Insets top="12.0" right="12.0" bottom="12.0" left="12.0"/>
                </padding>

                <Label text="Filter" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                <TitledPane text="Resedatum" expanded="true">
                    <content>
                        <VBox spacing="8.0">
                            <Label text="Avgång (från):"/>
                            <DatePicker fx:id="fromDatePicker"/>
                            <Label text="Avgång (till):"/>
                            <DatePicker fx:id="toDatePicker"/>
                        </VBox>
                    </content>
                </TitledPane>

                <TitledPane text="Pris" expanded="false">
                    <content>
                        <VBox spacing="8.0">
                            <Label text="Maxpris (SEK):"/>
                            <Spinner fx:id="maxPriceSpinner" editable="true"/>
                        </VBox>
                    </content>
                </TitledPane>

                <TitledPane text="Allergener" expanded="false">
                    <content>
                        <VBox spacing="6.0">
                            <CheckBox fx:id="allergenGluten" text="Gluten"/>
                            <CheckBox fx:id="allergenLactose" text="Laktos"/>
                            <CheckBox fx:id="allergenNuts" text="Nötter"/>
                            <CheckBox fx:id="allergenSoy" text="Soja"/>
                        </VBox>
                    </content>
                </TitledPane>

                <Region VBox.vgrow="ALWAYS"/>
                <Button fx:id="clearFiltersButton" text="Rensa filter" maxWidth="1.7976931348623157E308"/>
            </VBox>

            <!-- Höger: steg/wizard -->
            <VBox spacing="10.0">
                <padding>
                    <Insets top="12.0" right="12.0" bottom="12.0" left="12.0"/>
                </padding>

                <TabPane fx:id="wizardTabs" tabClosingPolicy="UNAVAILABLE">
                    <!-- Steg 1 -->
                    <Tab text="1. Matpaket">
                        <BorderPane>
                            <top>
                                <VBox spacing="8.0">
                                    <Label text="Välj ett matpaket"
                                           style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                                    <Label fx:id="availabilityHintLabel"
                                           text="Tips: Fullbokade paket ska markeras tydligt och inte kunna bokas."
                                           style="-fx-text-fill: #666666;"/>
                                </VBox>
                            </top>

                            <center>
                                <TableView fx:id="mealPackageTable">
                                    <columns>
                                        <TableColumn fx:id="colPkgName" text="Namn" prefWidth="220.0"/>
                                        <TableColumn fx:id="colPkgType" text="Typ" prefWidth="120.0"/>
                                        <TableColumn fx:id="colPkgAllergens" text="Allergener" prefWidth="160.0"/>
                                        <TableColumn fx:id="colPkgPrice" text="Pris" prefWidth="90.0"/>
                                        <TableColumn fx:id="colPkgSeats" text="Platser kvar" prefWidth="110.0"/>
                                        <TableColumn fx:id="colPkgStatus" text="Status" prefWidth="110.0"/>
                                    </columns>
                                </TableView>
                            </center>

                            <bottom>
                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                    <padding>
                                        <Insets top="10.0" right="0.0" bottom="0.0" left="0.0"/>
                                    </padding>
                                    <Label text="Valt paket:"/>
                                    <Label fx:id="selectedPackageLabel" text="(inget valt)"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="packageErrorLabel" text=""
                                           style="-fx-text-fill: #b00020;"/>
                                </HBox>
                            </bottom>
                        </BorderPane>
                    </Tab>

                    <!-- Steg 2 -->
                    <Tab text="2. Kund &amp; resenärer">
                        <VBox spacing="12.0">
                            <Label text="Kund &amp; resenärer (en bokning kan ha flera personer)"
                                   style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                            <SplitPane dividerPositions="0.52">
                                <!-- Vänster: Kunduppgifter -->
                                <VBox spacing="10.0">
                                    <Label text="Kunduppgifter" style="-fx-font-weight: bold;"/>

                                    <GridPane hgap="10.0" vgap="10.0">
                                        <columnConstraints>
                                            <ColumnConstraints minWidth="150.0" halignment="RIGHT"/>
                                            <ColumnConstraints hgrow="ALWAYS"/>
                                        </columnConstraints>

                                        <Label text="Förnamn:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                        <TextField fx:id="firstNameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                        <Label text="Efternamn:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                        <TextField fx:id="lastNameField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                                        <Label text="E-post:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                        <TextField fx:id="emailField" promptText="namn@exempel.se"
                                                   GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                                        <Label text="Telefon:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                        <TextField fx:id="phoneField" promptText="+46..."
                                                   GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                                        <Label text="Kund-ID/personnr:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                                        <TextField fx:id="customerIdField" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                                        <Label text="Kommentar:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                                        <TextArea fx:id="notesArea" prefRowCount="4"
                                                  GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                                    </GridPane>

                                    <Label fx:id="customerValidationLabel" text=""
                                           style="-fx-text-fill: #b00020;"/>
                                </VBox>

                                <!-- Höger: Resenärer i bokningen -->
                                <VBox spacing="10.0">
                                    <HBox spacing="10.0" alignment="CENTER_LEFT">
                                        <Label text="Resenärer i bokningen" style="-fx-font-weight: bold;"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Button fx:id="addTravelerButton" text="Lägg till"/>
                                        <Button fx:id="removeTravelerButton" text="Ta bort"/>
                                    </HBox>

                                    <TableView fx:id="travelersTable">
                                        <columns>
                                            <TableColumn fx:id="colTravelerFirstName" text="Förnamn" prefWidth="140.0"/>
                                            <TableColumn fx:id="colTravelerLastName" text="Efternamn" prefWidth="140.0"/>
                                            <TableColumn fx:id="colTravelerId" text="ID/personnr" prefWidth="140.0"/>
                                            <TableColumn fx:id="colTravelerNotes" text="Notering" prefWidth="160.0"/>
                                        </columns>
                                    </TableView>

                                    <Label fx:id="travelersHintLabel"
                                           text="Minst en resenär måste finnas i bokningen innan du kan gå vidare."
                                           style="-fx-text-fill: #666666;"/>
                                    <Label fx:id="travelersValidationLabel" text=""
                                           style="-fx-text-fill: #b00020;"/>
                                </VBox>
                            </SplitPane>
                        </VBox>
                    </Tab>

                    <!-- Steg 3 -->
                    <Tab text="3. Sammanfattning">
                        <VBox spacing="12.0">
                            <Label text="Sammanfattning"
                                   style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                            <TitledPane text="Bokningsdetaljer" expanded="true">
                                <content>
                                    <GridPane hgap="10.0" vgap="10.0">
                                        <columnConstraints>
                                            <ColumnConstraints minWidth="160.0" halignment="RIGHT"/>
                                            <ColumnConstraints hgrow="ALWAYS"/>
                                        </columnConstraints>

                                        <Label text="Matpaket:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                        <Label fx:id="summaryPackage" text="—" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                        <Label text="Pris:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                        <Label fx:id="summaryPrice" text="—" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                                        <Label text="Kund:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                        <Label fx:id="summaryCustomer" text="—" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                                        <Label text="Kontakt:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                        <Label fx:id="summaryContact" text="—" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                                        <Label text="Antal resenärer:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                                        <Label fx:id="summaryTravelerCount" text="—" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                                    </GridPane>
                                </content>
                            </TitledPane>

                            <TitledPane text="Resenärer" expanded="false">
                                <content>
                                    <TableView fx:id="summaryTravelersTable" prefHeight="180.0">
                                        <columns>
                                            <TableColumn fx:id="colSumTravelerName" text="Namn" prefWidth="260.0"/>
                                            <TableColumn fx:id="colSumTravelerId" text="ID/personnr" prefWidth="160.0"/>
                                        </columns>
                                    </TableView>
                                </content>
                            </TitledPane>

                            <Label text="Bokningsbekräftelse skapas vid bekräftelse."
                                   style="-fx-text-fill: #666666;"/>

                            <Label fx:id="summaryErrorLabel" text=""
                                   style="-fx-text-fill: #b00020;"/>
                        </VBox>
                    </Tab>
                </TabPane>
            </VBox>
        </SplitPane>
    </center>

    <bottom>
        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <padding>
                <Insets top="10.0" right="12.0" bottom="12.0" left="12.0"/>
            </padding>

            <Label text="Systemmeddelande:"/>
            <Label fx:id="statusLabel" text="Redo" style="-fx-text-fill: #333333;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button fx:id="backButton" text="Tillbaka"/>
            <Button fx:id="nextButton" text="Nästa"/>
            <Button fx:id="confirmButton" text="Bekräfta &amp; Spara" defaultButton="true"/>
        </HBox>
    </bottom>

</BorderPane>
